<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
version="3.1">
<display-name>CoffeeShopManager</display-name>
<!-- ■■■ WELCOME FILE ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■ -->
<welcome-file-list>
<welcome-file>index.jsp</welcome-file>
</welcome-file-list>
<!-- ■■■ SERVLET DEFINITIONS ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■ -->
<!-- MenuServlet: loads menu items and forwards to index.jsp -->
<servlet>
<servlet-name>MenuServlet</servlet-name>
<servlet-class>servlet.MenuServlet</servlet-class>
</servlet>
<!-- CartServlet: add / remove / clear cart items in session -->
<servlet>
<servlet-name>CartServlet</servlet-name>
<servlet-class>servlet.CartServlet</servlet-class>
</servlet>
<!-- CheckoutServlet: reads session cart, saves to DB -->
<servlet>
<servlet-name>CheckoutServlet</servlet-name>
<servlet-class>servlet.CheckoutServlet</servlet-class>
</servlet>
<!-- AdminLoginServlet: verifies admin credentials, sets session -->
<servlet>
<servlet-name>AdminLoginServlet</servlet-name>
<servlet-class>servlet.AdminLoginServlet</servlet-class>
</servlet>
<!-- AdminDashboardServlet: loads orders, handles status updates -->
<servlet>
<servlet-name>AdminDashboardServlet</servlet-name>
<servlet-class>servlet.AdminDashboardServlet</servlet-class>
</servlet>
<!-- ManageMenuServlet: add / delete menu items -->
<servlet>
<servlet-name>ManageMenuServlet</servlet-name>
<servlet-class>servlet.ManageMenuServlet</servlet-class>
</servlet>
<!-- ReportServlet: loads report data, forwards to report.jsp -->
<servlet>
<servlet-name>ReportServlet</servlet-name>
<servlet-class>servlet.ReportServlet</servlet-class>
</servlet>
<!-- ReportPdfServlet: generates downloadable PDF report -->
<servlet>
<servlet-name>ReportPdfServlet</servlet-name>
<servlet-class>servlet.ReportPdfServlet</servlet-class>
</servlet>
<!-- AdminLogoutServlet: clears admin session, redirects to login -->
<servlet>
<servlet-name>AdminLogoutServlet</servlet-name>
<servlet-class>servlet.AdminLogoutServlet</servlet-class>
</servlet>
<!-- ■■■ URL MAPPINGS ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■ -->
<servlet-mapping>
<servlet-name>MenuServlet</servlet-name>
<url-pattern>/menu</url-pattern> <!-- href="menu" -->
</servlet-mapping>
<servlet-mapping>
<servlet-name>CartServlet</servlet-name>
<url-pattern>/cart</url-pattern> <!-- action="cart" -->
</servlet-mapping>
<servlet-mapping>
<servlet-name>CheckoutServlet</servlet-name>
<url-pattern>/checkout</url-pattern> <!-- action="checkout" -->
</servlet-mapping>
<servlet-mapping>
<servlet-name>AdminLoginServlet</servlet-name>
<url-pattern>/adminLogin</url-pattern> <!-- action="adminLogin" -->
</servlet-mapping>
<servlet-mapping>
<servlet-name>AdminDashboardServlet</servlet-name>
<url-pattern>/adminDashboard</url-pattern>
</servlet-mapping>
<servlet-mapping>
<servlet-name>ManageMenuServlet</servlet-name>
<url-pattern>/manageMenu</url-pattern>
</servlet-mapping>
<servlet-mapping>
<servlet-name>ReportServlet</servlet-name>
<url-pattern>/report</url-pattern>
</servlet-mapping>
<servlet-mapping>
<servlet-name>ReportPdfServlet</servlet-name>
<url-pattern>/reportPdf</url-pattern>
</servlet-mapping>
<servlet-mapping>
<servlet-name>AdminLogoutServlet</servlet-name>
<url-pattern>/adminLogout</url-pattern>
</servlet-mapping>
<session-config>
<session-timeout>30</session-timeout>
</session-config>
</web-app>